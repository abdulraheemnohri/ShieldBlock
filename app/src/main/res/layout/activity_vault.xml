<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/emerald_dark_bg">
    <com.example.shieldblock.ui.AuraBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:title="Configuration Vault"
        app:titleTextColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CENTRAL SECURITY VAULT"
            android:textColor="@color/emerald_accent"
            android:textSize="12sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginBottom="32dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/exportBtn"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="EXPORT AEGIS PAYLOAD"
            app:cornerRadius="12dp"
            android:layout_marginBottom="16dp" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/importBtn"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="IMPORT VAULT PAYLOAD"
            app:cornerRadius="12dp" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Payloads contain all rules, firewall mitigations, and technical preferences in raw JSON format."
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:gravity="center" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
