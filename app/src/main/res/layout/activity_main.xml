<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/emerald_dark_bg">
    <com.example.shieldblock.ui.AuraBackgroundView
        android:id="@+id/auraBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AEGIS ULTRA PLUS"
                android:textColor="@color/emerald_accent"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />
            <com.example.shieldblock.ui.AegisCoreView
                android:id="@+id/aegisCore"
                android:layout_width="280dp"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:layout_marginTop="32dp" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="@color/emerald_card_bg"
                app:cardCornerRadius="16dp"
                app:strokeWidth="1dp"
                app:strokeColor="#3386FEA7">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/statusHud"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="PROTOCOL: READY\nSENTINEL: SCANNING"
                        android:textColor="@android:color/white"
                        android:fontFamily="monospace"
                        android:textSize="12sp" />
                    <com.example.shieldblock.ui.ThroughputOscilloscope
                        android:id="@+id/oscilloscope"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <TextView
                android:id="@+id/threatTicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="SENTINEL ACTIVE: MONITORING STREAMS..."
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:singleLine="true"
                android:ellipsize="marquee" />
        </LinearLayout>
    </ScrollView>
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/firewallFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="FIREWALL"
        app:icon="@drawable/ic_security"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        android:backgroundTint="@color/emerald_accent"
        android:textColor="@android:color/black"
        app:iconTint="@android:color/black" />
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/emerald_card_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:itemIconTint="@color/nav_item_selector"
        app:itemTextColor="@color/nav_item_selector"
        app:menu="@menu/bottom_nav_menu" />
</androidx.constraintlayout.widget.ConstraintLayout>