<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/emerald_dark_bg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rule Forge"
        android:textColor="@color/emerald_accent"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Pattern or Regex"
        app:boxStrokeColor="@color/emerald_accent"
        app:hintTextColor="@color/emerald_accent"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        xmlns:app="http://schemas.android.com/apk/res-auto">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/ruleInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/regexToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable Regex Engine"
        android:textColor="@android:color/white"
        android:buttonTint="@color/emerald_accent"
        android:layout_marginTop="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Regex: ^[a-z0-9]+\\.tracking\\.com$"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:layout_marginTop="4dp"/>
</LinearLayout>
